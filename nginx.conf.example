# ============================================================
#  Nginx — Configuração para produção
#  Arquivo: /etc/nginx/sites-available/copa-medicina
#
#  Instruções:
#  1. Copie este arquivo para /etc/nginx/sites-available/copa-medicina
#  2. Substitua "seu-dominio.com" pelo seu domínio real
#  3. Crie o link simbólico:
#     sudo ln -s /etc/nginx/sites-available/copa-medicina /etc/nginx/sites-enabled/
#  4. Teste: sudo nginx -t
#  5. Recarregue: sudo systemctl reload nginx
#
#  Para HTTPS com Let's Encrypt:
#     sudo certbot --nginx -d seu-dominio.com
# ============================================================

server {
    listen 80;
    server_name seu-dominio.com www.seu-dominio.com;

    # Logs
    access_log /var/log/nginx/copa-medicina.access.log;
    error_log  /var/log/nginx/copa-medicina.error.log;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    location / {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;

        # WebSocket (Socket.IO)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_cache_bypass $http_upgrade;

        # Timeout para WebSocket
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }
}
